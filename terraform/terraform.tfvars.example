# =============================================================================
# Interview Arena AI - Terraform Variables Example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to version control.
# =============================================================================

# General
environment  = "dev"
aws_region   = "us-east-1"

# Networking (defaults are fine for dev)

# Database (sensitive - set manually)
database_password = "your-strong-password-here"

# Secrets (sensitive - set manually)
jwt_secret        = "your-jwt-secret-min-32-characters-long"
jwt_refresh_secret = "your-jwt-refresh-secret-min-32-characters-long"
gemini_api_key    = "your-gemini-api-key"

# Domain (optional for dev)
# domain_name      = "app.interviewarena.com"
# hosted_zone_name = "interviewarena.com"

# Monitoring (optional)
# alarm_email       = "alerts@interviewarena.com"
