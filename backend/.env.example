# =============================================================================
# Interview Arena Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================================

# Server
PORT=5000
NODE_ENV=development

# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interviewarena

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# AWS (for DynamoDB - optional in dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Uploads
MAX_FILE_SIZE=5242880
