generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  passwordHash        String
  name                String
  role                Role                @default(CANDIDATE)
  status              AccountStatus       @default(ACTIVE)
  avatarUrl           String?
  emailVerified       Boolean             @default(false)
  rememberMe          Boolean             @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  achievements        Achievement[]
  candidateProfile    CandidateProfile?
  interviewResults    InterviewResult[]
  createdTemplates    InterviewTemplate[] @relation("TemplateCreator")
  interviews          Interview[]         @relation("CandidateInterviews")
  recruiterInterviews Interview[]         @relation("RecruiterInterviews")
  sentInvitations     Invitation[]        @relation("SenderInvitations")
  notifications       Notification[]
  recruiterProfile    RecruiterProfile?

  @@map("users")
}

model CandidateProfile {
  id                String           @id @default(uuid())
  userId            String           @unique
  phone             String?
  location          String?
  title             String?
  bio               String?
  resumeUrl         String?
  resumeScore       Int?
  profileCompletion Int              @default(0)
  portfolioUrl      String?
  githubUrl         String?
  linkedinUrl       String?
  twitterUrl        String?
  company           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  certifications    Certification[]
  skills            Skill[]
  workExperience    WorkExperience[]

  @@map("candidate_profiles")
}

model Skill {
  id           String           @id @default(uuid())
  profileId    String
  name         String
  level        String           @default("Intermediate")
  endorsements Int              @default(0)
  createdAt    DateTime         @default(now())
  profile      CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Certification {
  id            String           @id @default(uuid())
  profileId     String
  name          String
  issuer        String
  issueDate     DateTime?
  expiryDate    DateTime?
  credentialUrl String?
  createdAt     DateTime         @default(now())
  profile       CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model WorkExperience {
  id          String           @id @default(uuid())
  profileId   String
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean          @default(false)
  description String?
  createdAt   DateTime         @default(now())
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("work_experiences")
}

model RecruiterProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  company   String?
  position  String?
  phone     String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recruiter_profiles")
}

model InterviewTemplate {
  id          String             @id @default(uuid())
  recruiterId String
  name        String
  category    String?
  difficulty  String             @default("Medium")
  duration    Int                @default(60)
  status      String             @default("active")
  usageCount  Int                @default(0)
  rating      Float              @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  recruiter   User               @relation("TemplateCreator", fields: [recruiterId], references: [id], onDelete: Cascade)
  interviews  Interview[]
  questions   TemplateQuestion[]

  @@map("interview_templates")
}

model TemplateQuestion {
  id         String            @id @default(uuid())
  templateId String
  question   String
  type       String            @default("coding")
  difficulty String            @default("Medium")
  timeLimit  Int?
  orderIndex Int               @default(0)
  skills     String[]
  createdAt  DateTime          @default(now())
  template   InterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_questions")
}

model Interview {
  id                 String             @id @default(uuid())
  candidateId        String
  recruiterId        String?
  templateId         String?
  status             InterviewStatus    @default(SCHEDULED)
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  duration           Int?
  pauseCount         Int                @default(0)
  totalPauseDuration Int                @default(0)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  answers            InterviewAnswer[]
  result             InterviewResult?
  candidate          User               @relation("CandidateInterviews", fields: [candidateId], references: [id], onDelete: Cascade)
  recruiter          User?              @relation("RecruiterInterviews", fields: [recruiterId], references: [id])
  template           InterviewTemplate? @relation(fields: [templateId], references: [id])
  invitation         Invitation?

  @@map("interviews")
}

model InterviewAnswer {
  id          String    @id @default(uuid())
  interviewId String
  question    String
  answer      String?
  code        String?
  score       Int?
  feedback    String?
  timeSpent   Int?
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("interview_answers")
}

model InterviewResult {
  id                 String    @id @default(uuid())
  interviewId        String    @unique
  userId             String?
  overallScore       Int       @default(0)
  technicalScore     Int       @default(0)
  communicationScore Int       @default(0)
  confidenceScore    Int       @default(0)
  aiFeedback         String?
  strengths          String[]
  weaknesses         String[]
  recommendations    String[]
  reportUrl          String?
  createdAt          DateTime  @default(now())
  interview          Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user               User?     @relation(fields: [userId], references: [id])

  @@map("interview_results")
}

model Invitation {
  id          String     @id @default(uuid())
  senderId    String
  email       String
  interviewId String?    @unique
  status      String     @default("pending")
  token       String     @unique @default(uuid())
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  interview   Interview? @relation(fields: [interviewId], references: [id])
  sender      User       @relation("SenderInvitations", fields: [senderId], references: [id])

  @@map("invitations")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@map("system_logs")
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAUSED
}
